# PostgreSQL — single instance, schemas separate services
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fairgig
POSTGRES_USER=fairgig_admin
POSTGRES_PASSWORD=your_strong_password_here

# Analytics reader (restricted DB user — see init.sql)
ANALYTICS_DB_USER=analytics_reader
ANALYTICS_DB_PASSWORD=your_analytics_reader_password

# JWT — same secret shared across all services for local validation
JWT_SECRET=your_256_bit_secret_here_minimum_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# Service ports
AUTH_SERVICE_PORT=8001
EARNINGS_SERVICE_PORT=8002
ANOMALY_SERVICE_PORT=8003
GRIEVANCE_SERVICE_PORT=8004
ANALYTICS_SERVICE_PORT=8005
CERTIFICATE_SERVICE_PORT=8006
FRONTEND_PORT=5173

# Frontend → backend (used in React's Vite config)
VITE_AUTH_URL=http://localhost:8001
VITE_EARNINGS_URL=http://localhost:8002
VITE_ANOMALY_URL=http://localhost:8003
VITE_GRIEVANCE_URL=http://localhost:8004
VITE_ANALYTICS_URL=http://localhost:8005
VITE_CERTIFICATE_URL=http://localhost:8006

# File uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp

# Rate limiting
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_API_PER_MINUTE=100
