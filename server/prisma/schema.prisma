// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}


// USING SOFT DELETE

enum Role {
  worker
  verifier
  analyst
  admin
}

model User {
  id           Int    @id @default(autoincrement())
  name         String
  email        String @unique
  passwordHash String @unique
  role         Role   @default(worker)

  earnings      Earning[]      @relation("WorkerEarnings")
  verifications Verification[] @relation("VerifierAssignments")
  roleRequests RoleRequest[]   @relation("UserRequests")
  refreshTokens RefreshToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

}

model RefreshToken {
  id          Int      @id @default(autoincrement())

  jti         String    @unique

  userId      Int
  user        User     @relation(fields: [userId], references: [id])

  tokenHash   String

  expiresAt   DateTime
  createdAt   DateTime @default(now())
  lastUsedAt   DateTime @updatedAt
  revokedAt   DateTime?

  @@index([userId])
  @@index([expiresAt])
}

enum Platform {
  foodpanda
  indrive
  yango
  other
}

model Earning {
  id Int @id @default(autoincrement())

  workerId Int
  worker   User @relation("WorkerEarnings",fields: [workerId],references: [id])

  amount      Int      @default(0)
  platform    Platform @default(other)
  hoursWorked Int
  deductions  Int      @default(0)
  earnedDate  DateTime @default(now())

  verifications Verification[] @relation("VerificationStatuses")


  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([workerId])
}

enum Status {
  pending
  approved
  rejected
}

model Verification {
  id Int @id @default(autoincrement())

  earningId Int
  earning   Earning @relation("VerificationStatuses",fields: [earningId],references: [id])

  verifierId Int
  verifier   User @relation("VerifierAssignments", fields: [verifierId], references: [id])

  status          Status  @default(pending)
  submissionProof String
  comment         String?


  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([earningId])
  @@index([verifierId])
}

enum RequestStatus {
  pending
  approved
  rejected
}

model RoleRequest {
  id Int @id @default(autoincrement())

  userId Int
  user User @relation("UserRequests",fields: [userId],references: [id])

  requestedRole Role
  status RequestStatus @default(pending)


  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}